class HellsPitCalculator:
    """Computes HellsPit field = Σ(θᵢᵛᵒˡᵗᵃᵍₑ · φˢʰᵃᵈᵒʷ) / ψᵐᵉᵐᵇʳᵃⁿᵉ."""
    def __init__(self):
        self.field_value = 0.0
        self.history = []
    
    def compute(self, engine):
        # θᵢᵛᵒˡᵗᵃᵍₑ – sum of entity energies (voltage)
        voltage = sum(e.energy for e in engine.social_hub.entities if e.alive)
        # φˢʰᵃᵈᵒʷ – hidden stressors (cracks, known failures)
        shadow = 0
        if hasattr(engine, 'pirate'):
            shadow += sum(engine.pirate.cracks.values())
            shadow += len(engine.pirate.known_failures) * 2
        # ψᵐᵉᵐᵇʳᵃⁿᵉ – membrane tension (from JYM)
        membrane_tension = engine.membrane.tension if hasattr(engine, 'membrane') else 1.0
        
        if membrane_tension == 0:
            field = 0
        else:
            field = (voltage * shadow) / membrane_tension
        
        self.field_value = field
        self.history.append(field)
        if len(self.history) > 100:
            self.history.pop(0)
        
        # If HellsPit > 1 → temporary wraith overflow (chaos saturates tent)
        if field > HELLSPIT_THRESHOLD:
            engine.add_log("HellsPit overflow! Chaos saturates the tent.")
            # Apply chaos effects
            for e in engine.social_hub.entities:
                e.energy += random.randint(-10, 10)
                e.x += random.choice([-1,0,1])
                e.y += random.choice([-1,0,1])
                e.x = max(0, min(engine.biome.w-1, e.x))
                e.y = max(0, min(engine.biome.h-1, e.y))
        
        return field

