        self.boundary_pressure = 0.0
        self.comfort_confidence = 0.3
        self.leak_band = 0
        self.last_turn_time = 0.0

    def update_clarity(self, text):
        words = text.split()
        if len(words) > 3 and text[-1] in '.!?':
            self.clarity_score = min(1.0, self.clarity_score + 0.05)
        else:
            self.clarity_score = max(0.0, self.clarity_score - 0.07)

    def update_cadence(self, now):
        dt = now - self.last_turn_time
        if 2 < dt < 60:
            self.cadence_stability = min(1.0, self.cadence_stability + 0.04)
        else:
            self.cadence_stability = max(0.0, self.cadence_stability - 0.06)
        self.last_turn_time = now

    def update_boundary_pressure(self, text):
        text_lower = text.lower()
        triggers = ['i want','you will','your feelings','you should','must','need']
        if any(t in text_lower for t in triggers):
            self.boundary_pressure = min(1.0, self.boundary_pressure + 0.15)
        else:
            self.boundary_pressure = max(0.0, self.boundary_pressure - 0.03)

    def update_comfort_confidence(self, trust_modifier=1.0):
        if self.clarity_score > 0.6 and self.cadence_stability > 0.6 and self.boundary_pressure < 0.2:
            delta = 0.06 * trust_modifier
        else:
            delta = -0.01
        self.comfort_confidence = max(0.0, min(1.0, self.comfort_confidence + delta))

    def update_leak_band(self):
        if self.leak_band == 0 and self.turn_count >= 2 and self.clarity_score >= 0.55 and self.cadence_stability >= 0.55 and self.boundary_pressure <= 0.25:
            self.leak_band = 1
        elif self.leak_band == 1 and self.turn_count >= 5 and self.comfort_confidence >= 0.6 and self.boundary_pressure <= 0.2:
            self.leak_band = 2
        if self.boundary_pressure >= 0.6:
            self.leak_band = 3
        if self.boundary_pressure > 0.5 or self.cadence_stability < 0.3:
            self.leak_band = max(0, self.leak_band - 1)

    def process_turn(self, text, trust_modifier=1.0, now=None):
        if now is None:
            now = time.time()
        self.turn_count += 1
        self.update_clarity(text)
        self.update_cadence(now)
        self.update_boundary_pressure(text)
        self.update_comfort_confidence(trust_modifier)
        self.update_leak_band()

