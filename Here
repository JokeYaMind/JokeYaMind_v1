        '5': ('Blaze cost multiplier', 'blaze_cost_mult', 0.5, 2.0),
    }
    for key, (name, _, minv, maxv) in params.items():
        current = get_nested_attr(engine, params[key][1]) if '.' not in params[key][1] else get_nested_attr(engine, params[key][1])
        print(f"  {key}. {name} (current: {current}) range [{minv}-{maxv}]")

    choice = input("Select parameter to change (or Enter to exit): ").strip()
    if choice in params:
        name, attr, minv, maxv = params[choice]
        try:
            new_val = float(input(f"New value for {name} ({minv}-{maxv}): "))
            if minv <= new_val <= maxv:
                set_nested_attr(engine, attr, new_val)
                print(f"{name} set to {new_val}")
            else:
                print("Value out of range.")
        except ValueError:
            print("Invalid number.")

def get_nested_attr(obj, attr_str):
    attrs = attr_str.split('.')
    for a in attrs:
        obj = getattr(obj, a)
    return obj

def set_nested_attr(obj, attr_str, value):
    attrs = attr_str.split('.')
    for a in attrs[:-1]:
        obj = getattr(obj, a)
    setattr(obj, attrs[-1], value)

