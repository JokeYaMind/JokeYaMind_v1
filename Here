class DesireCalculator:
    """Computes desire = ((pressure * will) / (1+uncertainty)) + (motivation * intent_clarity)."""
    @staticmethod
    def compute(pressure, will, uncertainty, motivation, intent_clarity):
        return ((pressure * will) / (1 + uncertainty)) + (motivation * intent_clarity)

