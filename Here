            # Choose what to bluff about
            bluff_type = random.choice(['energy_low', 'energy_high', 'interest', 'disinterest'])
            self.bluffs[entity.uid] = (bluff_type, target.uid)
            # Effect: target misreads entity's state
            if bluff_type == 'energy_low':
                target.perception[entity.uid] = entity.energy * 0.5
            elif bluff_type == 'energy_high':
                target.perception[entity.uid] = entity.energy * 1.5
            # etc.
            return True
        return False
    
    def resolve_bluff(self, entity):
        if entity.uid in self.bluffs:
            # Bluff expires after one use
            del self.bluffs[entity.uid]
            return True
        return False

