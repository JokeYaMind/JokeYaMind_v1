DEFAULT_TICKS_PER_SECOND = 1.0

# Maximum offline ticks to process at once (to prevent freezing)
MAX_OFFLINE_TICKS = 10000

# -----------------------------------------------------------------------------
# OFFLINE TIME TRACKING
# -----------------------------------------------------------------------------

class OfflineTimeManager:
    """Manages offline time accumulation and catch‑up."""
    def __init__(self, engine):
        self.engine = engine
        self.ticks_per_second = DEFAULT_TICKS_PER_SECOND
        self.last_real_time = time.time()
        self.offline_ticks_processed = 0

    def update_last_time(self):
        """Call when saving or after catching up."""
        self.last_real_time = time.time()

    def compute_offline_ticks(self):
        """Calculate how many ticks have passed since last update."""
        elapsed = time.time() - self.last_real_time
        ticks = int(elapsed * self.ticks_per_second)
        return min(ticks, MAX_OFFLINE_TICKS)

    def run_offline_ticks(self, ticks):
        """Run N ticks without rendering or user input."""
        if ticks <= 0:
            return
        print(f"⏳ Processing {ticks} offline ticks...")
        for i in range(ticks):
            self.engine.tick()  # normal tick, but no render
            if i % 100 == 0 and i > 0:
                print(f"   ... {i}/{ticks} ticks done")
        self.offline_ticks_processed += ticks
        self.update_last_time()
        print(f"✅ Offline ticks complete. World has evolved.")

    def catch_up(self):
        """Run offline ticks based on elapsed real time."""
        ticks = self.compute_offline_ticks()
        if ticks > 0:
            self.run_offline_ticks(ticks)
        else:
            self.update_last_time()  # just update timestamp

