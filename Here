    """Gates tier permissions."""
    def __init__(self):
        self.thresholds = [0.2, 0.4, 0.6, 0.8]
    def check(self, affinity_vector, target_tier):
        avg = (affinity_vector.trust + affinity_vector.safety +
               affinity_vector.reciprocity + affinity_vector.autonomy +
               affinity_vector.coherence) / 5
        return avg >= self.thresholds[target_tier]

