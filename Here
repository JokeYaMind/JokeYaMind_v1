class SoilStateMachine:
    """Manages soil states for each tile."""
    def __init__(self, width, height):
        self.width = width
        self.height = height
        self.states = np.zeros((width, height), dtype=int)  # default Mineral
        self.timers = np.zeros((width, height))  # for state duration
    
    def update(self, biome, entities):
        for x in range(self.width):
            for y in range(self.height):
                # Determine state based on conditions
                fungi = biome.fungi[x][y]
                nutrients = biome.nutrients[x][y]
                water = biome.water[x][y]
                entity_present = any(e.x == x and e.y == y for e in entities if e.alive)
                
                # Transition rules
                current = self.states[x][y]
                if current == SOIL_MINERAL:
                    if fungi > 0.3 and water > 0.4:
                        self.states[x][y] = SOIL_CARNIVAL
                        self.timers[x][y] = 10
                elif current == SOIL_CARNIVAL:
                    if entity_present and random.random() < 0.1:
                        self.states[x][y] = SOIL_COMPOST
                        self.timers[x][y] = 20
                    elif nutrients < 0.2:
                        self.states[x][y] = SOIL_FALLOW
                elif current == SOIL_COMPOST:
                    if self.timers[x][y] <= 0:
                        self.states[x][y] = SOIL_MYCELIAL
                    else:
                        self.timers[x][y] -= 1
                elif current == SOIL_MYCELIAL:
                    if nutrients > 0.8:
                        self.states[x][y] = SOIL_CARNIVAL
                elif current == SOIL_FALLOW:
                    if water > 0.5 and nutrients > 0.1:
                        self.states[x][y] = SOIL_MINERAL
                elif current == SOIL_REJECTION:
                    # Rejection is permanent unless reset
                    pass
                
                # Apply soil effects
                biome.nutrients[x][y] += SOIL_NUTRIENT_FLOW[self.states[x][y]] * 0.01
                biome.nutrients[x][y] = max(0.0, min(1.0, biome.nutrients[x][y]))
                
                # Viscosity affects entity movement (applied in entity update)
    
    def get_viscosity(self, x, y):
        return SOIL_VISCOSITY[self.states[x][y]]

