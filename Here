        self.predator_prey_beta = 0.01
        self.predator_prey_delta = 0.01
        self.predator_prey_gamma = 0.05
        self.energy_series = deque(maxlen=100)  # for martingale check

    def tick(self):
        # 1. SDE for nutrients and water (already in finance_eco, but we'll make it more dynamic)
        for x in range(self.engine.biome.w):
            for y in range(self.engine.biome.h):
                dW_n = np.random.randn() * self.resource_volatility
                dW_w = np.random.randn() * self.resource_volatility
                self.engine.biome.nutrients[x][y] = self.sde_evolution(
                    self.engine.biome.nutrients[x][y], 0.001, 0.01, 0.01, dW_n)
                self.engine.biome.water[x][y] = self.sde_evolution(
                    self.engine.biome.water[x][y], 0.001, 0.01, 0.01, dW_w)
                self.engine.biome.nutrients[x][y] = max(0, min(1, self.engine.biome.nutrients[x][y]))
                self.engine.biome.water[x][y] = max(0, min(1, self.engine.biome.water[x][y]))

        # 2. Lotka-Volterra for predator/prey influence on reproduction rates
        predators = len([e for e in self.engine.social_hub.entities if e.role == "PREDATOR" and e.alive])
        preys = len([e for e in self.engine.social_hub.entities if e.role in ("KID","NORMAL") and e.alive])
        if predators > 0 and preys > 0:
            new_pred, new_prey = self.lotka_volterra(
                predators, preys,
                self.predator_prey_alpha,
                self.predator_prey_beta,
                self.predator_prey_delta,
                self.predator_prey_gamma,
                0.01)
            # Influence birth rates: reproduction chance modified
            self.engine.reproduction_predator_mod = new_pred / predators if predators else 1
            self.engine.reproduction_prey_mod = new_prey / preys if preys else 1
        else:
            self.engine.reproduction_predator_mod = 1
            self.engine.reproduction_prey_mod = 1

        # 3. Correlation between entity energies (market analogy)
        energies = [e.energy for e in self.engine.social_hub.entities if e.alive]
        if len(energies) > 1:
            # Create two series: current and lagged
            if len(self.energy_series) > 10:
                corr = self.correlation(list(self.energy_series)[-10:], energies[-10:])
                if corr > 0.8:
                    self.engine.add_log("High energy correlation – possible bubble.")
                elif corr < -0.5:
                    self.engine.add_log("Negative correlation – divergence.")

        # Store current energies for next tick
        self.energy_series.append(energies)

        # 4. Martingale check on companion energy
        if self.engine.social_hub.companion:
            comp_energy = self.engine.social_hub.companion.energy
            self.engine.companion_energy_series.append(comp_energy)
            if len(self.engine.companion_energy_series) > 20:
                if self.martingale_check(list(self.engine.companion_energy_series)):
                    self.engine.add_log("Companion energy follows martingale – fair.")

    def sde_evolution(self, X, mu, sigma, dt, dW):
        return X + mu * dt + sigma * dW

    def lotka_volterra(self, A, B, alpha, beta, delta, gamma, dt):
        dA = (alpha * A - beta * A * B) * dt
        dB = (delta * A * B - gamma * B) * dt
        return A + dA, B + dB

    def correlation(self, x, y):
        return np.corrcoef(x, y)[0,1] if len(x) > 1 else 0

    def martingale_check(self, series):
        diffs = np.diff(series)
        return np.abs(np.mean(diffs)) < 1e-6

