        init_vote(self)
    engine_class.__init__ = new_init

    # Extend tick to update vote
    original_tick = engine_class.tick
    def tick_with_vote(self, user_input=None):
        original_tick(self, user_input)
        if self.config.wraith_vote_enabled:
