        self.theta_es = 0.0
        # Precompute rotation matrices (simplified: rotate in the plane of two axes)
        # We'll use a composition of rotations in the (axis, underview) and (axis, echoside) planes.

    def rotate_vector(self, v, t_uv, t_es):
        """Apply underview and echoside rotations to a 7D vector."""
        # Rotation in plane (0,4): underview affects first dimension
        c, s = math.cos(t_uv), math.sin(t_uv)
        v0, v4 = v[0], v[4]
        v[0] = c * v0 - s * v4
        v[4] = s * v0 + c * v4

        # Rotation in plane (1,5): echoside affects second dimension
        c, s = math.cos(t_es), math.sin(t_es)
        v1, v5 = v[1], v[5]
        v[1] = c * v1 - s * v5
        v[5] = s * v1 + c * v5

        # Also couple underview with echoside? Not needed for basic effect.
        return v

