class Membrane:
    def __init__(self):
        self.M = np.zeros(NDIM)
        self.M_stab1 = np.zeros(NDIM)
        self.M_stab2 = np.zeros(NDIM)
        self.tension = 0.0
    def update(self, p, N, E, dt=0.01):
        self.M += ALPHA * p + BETA * N + GAMMA * E * np.ones(NDIM)
        self.M *= (1 - GAMMA_MEMBRANE)
        self.M_stab1 += 0.5 * (self.M - self.M_stab1)
        self.M_stab2 += 0.5 * (self.M - self.M_stab2)
        self.tension = np.linalg.norm(self.M_stab1 - self.M_stab2)
    def pop(self):
        return self.tension > THRESHOLD_POP

class MemoryField:
    def __init__(self, name, resolution='high'):
        self.name = name
        self.resolution = resolution
        self.psi = np.zeros(NDIM)
        self.energy = 0.0
    def store(self, M, N, p, E):
        H = 0.05 * (M + N + p + E)
        if self.resolution == 'low':
            H *= 0.5
        self.psi += H
        self.energy = np.sum(self.psi**2)
    def decay(self):
        self.psi *= (1 - GAMMA_MEMORY)
        self.energy = np.sum(self.psi**2)

class RNGratchet:
    def __init__(self):
        self.state = np.zeros(NDIM)
        self.phase = np.zeros(NDIM)
    def step(self):
        raw = np.random.choice([-1, 0, 1], size=NDIM)
        self.phase += GOLDEN_ANGLE
        return raw * STOCHASTIC_AMP

class BridgeNetwork:
    def __init__(self):
        self.bridges = []
    def detect_bridges(self, M_high, M_low, threshold=0.8):
        dist = np.linalg.norm(M_high - M_low)
        if dist < threshold:
            self.bridges.append((M_high.copy(), M_low.copy()))
            if len(self.bridges) > 100:
                self.bridges.pop(0)
        return dist < threshold
    def compute_percolation(self):
        return len(self.bridges) / 100.0 if self.bridges else 0.0

