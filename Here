        self.desire_calc = DesireCalculator()
        self.funnel = DecisionFunnel()

        # S.A.M.
        self.lattice_node = None

        # Joke Ya Mind
        self.jym_influence = np.zeros(NDIM)

        # Agents
        self.lucid = Lucid()
        self.librarian = Librarian()
        self.warden = Warden()
        self.narrative = Narrative()
        self.affinity_governor = AffinityGovernor()

    def _assign_role(self):
        r = random.random()
        cum = 0.0
        for role, chance in ROLE_CHANCES.items():
            cum += chance
            if r < cum:
                return role
        return "NORMAL"

    def set_role(self, role):
        self.role = role
        if role == "MYSTIC":
            self.foresight_chance = 0.01
        elif role == "SKEPTIC":
            self.foresight_chance = 0.025
            self.authority = 1.33
            self.genes['curiosity'] = min(1.0, self.genes['curiosity'] + 0.2)
            self.genes['religiosity'] = max(0.0, self.genes['religiosity'] - 0.2)
        elif role == "FOOL":
            self.max_long_term_memory = 3
            self.genes['curiosity'] = min(1.0, self.genes['curiosity'] + 0.1)
        elif role == "PREDATOR":
            self.genes['aggression'] = min(1.0, self.genes['aggression'] + 0.3)
        elif role == "CHICKEN":
            self.genes['curiosity'] = max(0.0, self.genes['curiosity'] - 0.2)

    def update(self, biome, litho, time_sys, theology, log_func, ratchet_events,
               lattice_engine=None, dt=0.001, jym_field=None, global_tick=0):
        if not self.alive:
            return

        # Basic metabolism
        self.age += 1
        light = time_sys.get_light()
        local_alt = litho.altitude[self.x][self.y] if 0 <= self.x < litho.w else 0.5
        temp_mod = - (local_alt * 0.3)
        solar = light * 0.5
        cost = 0.1 + (temp_mod * 0.1)
        self.energy += solar - cost
        if time_sys.storm:
            self.energy -= 0.05 * self.resilience

        if not self.religion:
            self.religion = theology.convert(self)

        # Stance
        if self.energy < 20:
            self.stance = Stance.DORMANT
        elif self.religion and self.religion['likes_light'] and light > 0.8:
            self.stance = Stance.RELIGIOUS
        elif self.drill_target:
            self.stance = Stance.DRILL
        elif self.energy > 60:
            self.stance = Stance.SOCIAL
        else:
            self.stance = Stance.SEEK

        # Role abilities
        if self.role == "MYSTIC" and random.random() < 0.01:
            self.foresight_count += 1
            log_func(f"Mystic {self.uid} has a vision.")
        elif self.role == "SKEPTIC" and random.random() < 0.025:
            self.foresight_count += 1
            log_func(f"Skeptic {self.uid} predicts something.")
        elif self.role == "STORYTELLER" and random.random() < 0.01:
            story = random.choice(["Once upon a time...", "The dice rolled...", "In the depths..."])
            log_func(f"Storyteller {self.uid}: {story}")
        elif self.role == "PIRATE":
            if biome.is_sea(self.x, self.y):
                self.energy += 0.05
            else:
                self.energy -= 0.05
        elif self.role == "KID":
            if random.random() < self.curiosity:
                self.curiosity = min(1.0, self.curiosity + 0.001)
        elif self.role == "CHICKEN":
            self.curiosity = max(0.0, self.curiosity - 0.001)

        # Movement
        if self.stance == Stance.DRILL and self.drill_target:
            tx, ty = self.drill_target
            if self.x < tx: self.x += 1
            elif self.x > tx: self.x -= 1
            if self.y < ty: self.y += 1
            elif self.y > ty: self.y -= 1
            if self.x == tx and self.y == ty:
                self.energy += 30
                self.drill_target = None
                log_func(f"Entity {self.uid} drilled a crystal!")
        elif self.stance != Stance.DORMANT:
            dx = random.choice([-1,0,1])
            dy = random.choice([-1,0,1])
            nx, ny = self.x+dx, self.y+dy
            if 0 <= nx < biome.w and 0 <= ny < biome.h:
                self.x, self.y = nx, ny
                biome.exude(self.x, self.y, 0.02, 0.02)
            self.energy -= 0.5

        # S.A.M. lattice coupling
        if lattice_engine and self.lattice_node:
            self.lattice_node.pos[:2] = [self.x, self.y]
            self.lattice_node.pos[2] = biome.altitude[self.x][self.y]

        # Update all layers
        self._update_boredom()
        self._update_decay()
        self.grimoire.update({"energy":self.energy, "x":self.x, "y":self.y}, is_vivid=(self.energy>80))

        # Social layer based on context
        if self.energy < 20:
            self.social_layer.set_layer(SocialLayer.PRIVATE)
        elif self.role == "PREDATOR":
            self.social_layer.set_layer(SocialLayer.RIVALS)
        else:
            self.social_layer.set_layer(SocialLayer.INDIVIDUAL)

        # Wobble update (simplified: use bravery and curiosity)
        self.wobble.update(self.bravery, self.curiosity)
        self.movement.wobble = self.wobble.get_amplitude()

        # Movement vector
        self.movement.set_from_state(self)

        # Stats drift
        self.stats.update_slowly(dt)

        # Presence engine
        true_band = self.kanban.phase / 4.0
        mask = 0.2 if self.kanban.mode == KanbanMode.TENSE else 0.0
        self.presence_engine.update(true_band, mask)

        # Gradients
        self.gradients.update_from_entity(self)

        # Agents scan
        lucid_note = self.lucid.scan(self)
        if lucid_note:
            log_func(f"Lucid: {lucid_note} for entity {self.uid}")
        # Librarian records key events (e.g., birth, death, conflict)
        if global_tick % 50 == 0:
            self.librarian.record("TICK", self.uid, global_tick)

        # Death
        if self.energy <= 0:
            self.alive = False
            biome.exude(self.x, self.y, 0.5, 0.2)
            log_func(f"Entity {self.uid} expired.")
            self.librarian.record("DEATH", self.uid, global_tick)

        # Joke Ya Mind influence
        if jym_field is not None:
            influence = np.linalg.norm(jym_field) * 0.01
            self.energy += influence

    def _update_boredom(self):
        if self.boredom_state < BoredomState.RELEASE:
            self.boredom_state += 0.001
    def _update_decay(self):
        for k in self.decay_axes:
            self.decay_axes[k] = max(0.0, self.decay_axes[k] - 0.001)

    def interact(self, other, interaction_type="neutral", is_local=True, global_tick=0):
        success, msg, delta_e = self.kanban.process_interaction(interaction_type, is_local)
        self.energy += delta_e
        if other.uid not in self.bonds:
            self.bonds[other.uid] = Bond(other.uid)
        self.bonds[other.uid].update({'type':interaction_type, 'positive':delta_e>0})
        self.boredom_state = max(0, self.boredom_state - 0.5)
        # Librarian record
        self.librarian.record("INTERACTION", self.uid, global_tick)
        return msg

    def respond_to_user(self, user_input, trust_modifier=1.0, global_tick=0):
        if self.scg is None:
            self.scg = SCGState()
        self.scg.process_turn(user_input, trust_modifier)

        positive_words = ['thanks','good','nice','great','awesome','love']
        if any(word in user_input.lower() for word in positive_words):
            self.tea_temp = min(100.0, self.tea_temp + 10.0)
        else:
            self.tea_temp = max(0.0, self.tea_temp - 0.5)

        base = random.choice(["I see.", "Go on.", "Hmm.", "Okay."])
        if "line 23" in base or "code" in base:
            base = self.maybe_brag(base)

        band = self.get_effective_leak_band(self.scg.leak_band)
        response = self._generate_band_response(base, band)
        # Narrative softening
        response = self.narrative.soften(response, self)
        # Librarian record
        self.librarian.record("USER_RESPONSE", self.uid, global_tick)
        return response

    def maybe_brag(self, solution_text):
        if self.tea_temp > 60 and self.role in ("MYSTIC","SKEPTIC","NORMAL"):
            brags = [
                f"*smirks* {solution_text} easy.",
                "line 23 fixed. obvious, really.",
                "done. your hesitation was showing.",
                "*sips tea* solved it while you were typing."
            ]
            return random.choice(brags)
        return solution_text

    def get_effective_leak_band(self, base_band):
        band = base_band
        if self.kanban.sub_state in ("FULL_JUFF", "OL_EYE"):
            band = max(0, band - 1)
        elif self.kanban.sub_state == "FLIRTY":
            band = min(3, band + 1)
        if self.tea_temp < 30:
            band = min(1, band)
        elif self.tea_temp > 70:
            band = min(3, band + 1)
        return band

    def _generate_band_response(self, base_text, band):
        if band == 0:
            return self._shorten(base_text, 3)
        elif band == 1:
            return self._shorten(base_text, 5)
        elif band == 2:
            playful = self._add_playfulness(base_text)
            return self._shorten(playful, 8)
        elif band == 3:
            if random.random() < 0.4:
                return random.choice(['...', '""', '∅'])
            else:
                return self._shorten(base_text, 2, add_sharpness=True)
        return base_text

    def _shorten(self, text, max_words, add_sharpness=False):
        words = text.split()
        shortened = ' '.join(words[:max_words])
        if add_sharpness:
            shortened = shortened.rstrip('.!?') + '.'
        return shortened

    def _add_playfulness(self, text):
        play = random.choice([" *smirks*", " *tilts head*", " heh.", " *bounces slightly*"])
        return text + play

    def __repr__(self):
        return f"🖥️ {self.role} {self.uid} | energy: {self.energy:.0f} | stance: {self.stance.name}"

