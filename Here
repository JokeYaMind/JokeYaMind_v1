import os
import time
import json
from datetime import datetime

# -----------------------------------------------------------------------------
# WRATH WORLD VOTE SYSTEM
# -----------------------------------------------------------------------------

class WraithVote:
    """
    Hidden mechanic that tracks collective entity states and triggers a world vote.
    The vote represents the world's desire to reset or transform.
    """
    def __init__(self, engine):
        self.engine = engine
        self.vote_progress = 0.0      # 0 to 1, when reaches 1, vote triggers
        self.vote_active = False
        self.vote_result = None       # "reset", "transformation", etc.
        self.last_vote_tick = 0
        self.vote_cooldown = 1000     # ticks between votes

        # Weighting factors
        self.boredom_weight = 1.0
        self.curiosity_weight = 1.0
        self.aspiration_weight = 1.0

    def update(self):
        """Calculate vote progress based on entity states."""
        if self.vote_active:
            # Vote in progress – check if resolved
            self._process_vote()
            return

        # Only update every 10 ticks to save performance
        if self.engine.time_sys.total_ticks % 10 != 0:
            return

        # Gather collective stats
        total_boredom = 0
        total_curiosity = 0
        total_aspiration = 0
        entity_count = 0

        for e in self.engine.social_hub.entities:
            if e.alive:
                # Boredom: from boredom_engine state (0-4 mapped to 0-1)
                boredom_val = e.boredom_engine.boredom_state / 4.0
                total_boredom += boredom_val

                # Curiosity: from e.curiosity
                total_curiosity += e.curiosity

                # Aspiration: from goal_trajectory length? or self_image? Let's use self_image as proxy
                aspiration_val = e.grimoire.self_image
                total_aspiration += aspiration_val

                entity_count += 1

        if entity_count == 0:
            return

        # Average values
        avg_boredom = total_boredom / entity_count
        avg_curiosity = total_curiosity / entity_count
        avg_aspiration = total_aspiration / entity_count

        # Compute contribution to vote progress
        contribution = (avg_boredom * self.boredom_weight +
                        avg_curiosity * self.curiosity_weight +
                        avg_aspiration * self.aspiration_weight) / 3.0

        # Progress increases faster when values are extreme
        self.vote_progress += contribution * 0.001

        # Clamp
        self.vote_progress = min(1.0, self.vote_progress)

        # Check if vote threshold reached
        if self.vote_progress >= 1.0 and (self.engine.time_sys.total_ticks - self.last_vote_tick) > self.vote_cooldown:
            self._trigger_vote()

    def _trigger_vote(self):
        """Start the vote process."""
        self.vote_active = True
        self.last_vote_tick = self.engine.time_sys.total_ticks
        self.engine.add_log("🌑 The Wraith stirs... a world vote begins!")

        # Determine possible outcomes based on current state
        # For now, simple: 50% reset, 50% transformation
        import random
        self.vote_result = random.choice(["reset", "transformation"])
        self.vote_progress = 0.0  # reset for next time

    def _process_vote(self):
        """Handle ongoing vote (could be multi‑tick). Here we resolve immediately."""
        if self.vote_result == "reset":
            self._world_reset()
        elif self.vote_result == "transformation":
            self._world_transformation()

        self.vote_active = False
        self.vote_result = None

    def _world_reset(self):
        """Reset the world while preserving some memory."""
        self.engine.add_log("💥 The Wraith World resets! All is new.")

        # Kill all entities, but leave some residue
        for e in self.engine.social_hub.entities:
            e.alive = False
            e.energy = 0

        # Spawn new entities in a fresh configuration
        self.engine._seed_entities()

        # Reset some global state
        self.engine.time_sys.total_ticks = 0
        self.engine.time_sys.day = 1
        self.engine.time_sys.hour = 6

        # Wraith log gets a special entry
        self.engine.wraith_log.append({
            'tick': 0,
            'event': 'WORLD_RESET',
            'invariant': self.engine.invariant
        })

    def _world_transformation(self):
        """Transform the world: mutate entities, change biome."""
        self.engine.add_log("🌀 The Wraith World transforms!")

        # Mutate all entities
        for e in self.engine.social_hub.entities:
            if e.alive:
                # Randomly change role
                new_role = random.choice(list(ROLE_CHANCES.keys()))
                e.set_role(new_role)
                # Adjust energy
                e.energy = max(30, min(100, e.energy + random.randint(-20, 20)))

        # Alter biome
        for x in range(self.engine.biome.w):
            for y in range(self.engine.biome.h):
                self.engine.biome.nutrients[x][y] = max(0, min(1, self.engine.biome.nutrients[x][y] + random.uniform(-0.2, 0.2)))
                self.engine.biome.water[x][y] = max(0, min(1, self.engine.biome.water[x][y] + random.uniform(-0.2, 0.2)))
                self.engine.biome.fungi[x][y] = max(0, min(1, self.engine.biome.fungi[x][y] + random.uniform(-0.1, 0.1)))

        # Wraith log entry
        self.engine.wraith_log.append({
            'tick': self.engine.time_sys.total_ticks,
            'event': 'WORLD_TRANSFORMATION',
            'invariant': self.engine.invariant
        })

    def force_vote(self):
        """Manually trigger a vote (e.g., from pause menu)."""
        if not self.vote_active:
            self._trigger_vote()

