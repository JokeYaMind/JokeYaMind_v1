class DecisionFunnel:
    """From many signals to one action."""
    def __init__(self):
        self.micro_votes = []   # list of (option, weight)
        self.macro_synthesis = None
        self.prediction = None
        self.constraint_check = None
        self.will_check = None
        self.final_action = None
    def process(self, entity, environment_signals):
        # Step 1: micro voting – each micro node suggests options
        self.micro_votes = [(f"action_{i}", random.random()) for i in range(5)]
        # Step 2: macro synthesis – combine into a few candidates
        candidates = ["wait", "approach", "withdraw", "probe"]
        # Step 3: prediction & scoring
        scores = [random.random() for _ in candidates]
        best_idx = np.argmax(scores)
        # Step 4: constraint check
        if entity.energy < 10:
            return "wait"   # can't act
        # Step 5: will check
        if entity.energy < 20 and candidates[best_idx] != "wait":
            return "wait"
        # Step 6: action
        return candidates[best_idx]

