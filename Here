class Curse:
    def __init__(self, name, effect, duration):
        self.name = name
        self.effect = effect  # function taking entity
        self.duration = duration
    def apply(self, entity):
        if self.duration > 0:
            self.effect(entity)
            self.duration -= 1
            return True
        return False

class Blessing:
    def __init__(self, name, effect, duration):
        self.name = name
        self.effect = effect
        self.duration = duration
    def apply(self, entity):
        if self.duration > 0:
            self.effect(entity)
            self.duration -= 1
            return True
        return False

def generate_curse(entity):
    curses = [
        Curse("Wandering", lambda e: setattr(e, 'x', e.x + random.choice([-1,1])), 10),
        Curse("Energy Drain", lambda e: setattr(e, 'energy', e.energy - 1), 5),
        Curse("Silence", lambda e: setattr(e, 'scg', None) if e.scg else None, 3),
        Curse("Confusion", lambda e: setattr(e, 'curiosity', e.curiosity * 0.8), 7)
    ]
    return random.choice(curses)

