def rg_step(m2, lam, dl=RG_STEP):
    """One‑loop RG flow for m² and λ (schematic)."""
    beta_m2 = lam / (16 * np.pi**2)
    beta_lam = 3 * lam**2 / (16 * np.pi**2)
    m2 += beta_m2 * dl
    lam += beta_lam * dl
    return m2, lam

def kink_solution(x, v=V_MIN, lam=LAMBDA_QUARTIC):
    """φ_kink(x) = v tanh( √(λ) v x / √2 )"""
    return v * np.tanh(np.sqrt(lam) * v * x / np.sqrt(2))

def percolation_threshold(bridges, total_nodes):
    if total_nodes == 0:
        return 0.0
    # Percolation: fraction of nodes that are part of a connected bridge network
    # Simplified: count unique nodes in bridges
    unique_nodes = set()
    for high, low in bridges:
        unique_nodes.add(tuple(high))
        unique_nodes.add(tuple(low))
    return len(unique_nodes) / total_nodes

