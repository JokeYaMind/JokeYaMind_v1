class GradientManager:
    """Manages refusal, comprehension, teacher/learner, grace gradients."""
    def __init__(self):
        self.refusal = RefusalLevel.NEUTRAL
        self.comprehension = ComprehensionLevel.IMMEDIATE
        self.teacher = TeacherLevel.NEUTRAL
        self.learner = LearnerLevel.MODERATE
        self.grace = GraceLevel.BALANCED
    def update_from_entity(self, entity):
        if entity.energy < 20:
            self.refusal = RefusalLevel.STRONG_BOUNDARY
        elif entity.energy > 80:
            self.refusal = RefusalLevel.PLAYFUL_REFUSAL
        else:
            self.refusal = RefusalLevel.NEUTRAL
        if hasattr(entity, 'scg') and entity.scg:
            if entity.scg.clarity_score > 0.8:
                self.comprehension = ComprehensionLevel.IMMEDIATE
            elif entity.scg.clarity_score < 0.3:
                self.comprehension = ComprehensionLevel.BAFFLED
            else:
                self.comprehension = ComprehensionLevel.DELAYED
        if entity.role == "MYSTIC":
            self.teacher = TeacherLevel.SOFT_GUIDE
        elif entity.role == "SKEPTIC":
            self.teacher = TeacherLevel.ASSERTIVE
        else:
            self.teacher = TeacherLevel.NEUTRAL
        if entity.affinity.trust > 0.7:
            self.grace = GraceLevel.GENEROUS
        else:
            self.grace = GraceLevel.BALANCED
    def get_response_modifier(self):
        # combine into a single multiplier for response length/richness
        mod = 1.0
        if self.refusal >= RefusalLevel.STRONG_BOUNDARY:
            mod *= 0.5
        if self.comprehension == ComprehensionLevel.BAFFLED:
            mod *= 0.3
        if self.teacher == TeacherLevel.SOFT_GUIDE:
            mod *= 1.2
        if self.grace == GraceLevel.GENEROUS:
            mod *= 1.1
        return mod

