class Kanban:
    """Relationship phase state machine."""
    def __init__(self):
        self.phase = KanbanPhase.ECLIPSE
        self.vector_bias = 0.0
        self.consent_level = 0.0
        self.coupling_strength = 0.0
        self.mode = KanbanMode.SOVEREIGN
        self.sub_state = None
        self.local_interactions = 0
        self.distant_interactions = 0

    def update_phase(self):
        if self.phase == KanbanPhase.ECLIPSE:
            if self.local_interactions > 1 or self.distant_interactions > 1:
                self.phase = KanbanPhase.CRESCENT
        elif self.phase == KanbanPhase.CRESCENT:
            if self.local_interactions > 3:
                self.phase = KanbanPhase.QUARTER
        elif self.phase == KanbanPhase.QUARTER:
            if self.vector_bias > 0.2:
                self.phase = KanbanPhase.GIBBOUS
        elif self.phase == KanbanPhase.GIBBOUS:
            if self.coupling_strength > 0.7:
                self.phase = KanbanPhase.FULL

    def update_mode(self):
        if self.vector_bias < -0.4:
            self.mode = KanbanMode.TENSE
            self.sub_state = "FULL_JUFF" if self.vector_bias < -0.7 else "OL_EYE"
        elif self.vector_bias > 0.4:
            self.mode = KanbanMode.LOOSE
            if self.phase == KanbanPhase.FULL and (self.local_interactions + self.distant_interactions) > 10:
                self.sub_state = "ADMIRING"
            else:
                self.sub_state = "FLIRTY"
        else:
            self.mode = KanbanMode.SOVEREIGN
            self.sub_state = None

    def process_interaction(self, interaction_type, is_local=True):
        if is_local:
            self.local_interactions += 1
        else:
            self.distant_interactions += 1

        if interaction_type == "challenge":
            self.vector_bias -= 0.2
        elif interaction_type == "playful":
            self.vector_bias += 0.1
        elif interaction_type == "support":
            if self.consent_level >= 0.7:
                self.vector_bias += 0.2
            else:
                self.vector_bias -= 0.1
                return (False, f"Support blocked: consent {self.consent_level:.2f} < 0.7", -0.1)

        self.vector_bias = max(-1.0, min(1.0, self.vector_bias))
        self.update_phase()
        if self.vector_bias > 0.5 and self.phase in (KanbanPhase.GIBBOUS, KanbanPhase.FULL):
            self.coupling_strength = min(1.0, self.coupling_strength + 0.05)
        self.update_mode()
        if self.vector_bias > 0.5 and self.phase in (KanbanPhase.GIBBOUS, KanbanPhase.FULL):
            self.consent_level = min(1.0, self.consent_level + 0.05)

        energy_delta = 0.0
        if self.mode == KanbanMode.LOOSE:
            energy_delta = 0.1
        elif self.mode == KanbanMode.TENSE:
            energy_delta = -0.1

        return (True, f"Vector: {self.vector_bias:.2f}, Mode: {self.mode}", energy_delta)

    def check_consent(self, required_level):
        if self.consent_level >= required_level:
            return True, "Access Granted."
        else:
            self.vector_bias -= 0.1
            self.update_mode()
            return False, f"Consent blocked: {self.consent_level:.2f} < {required_level}"

    def get_state(self):
        phase_names = ["ECLIPSE","CRESCENT","QUARTER","GIBBOUS","FULL"]
        return {
            'phase': phase_names[self.phase],
            'vector': self.vector_bias,
            'consent': self.consent_level,
            'coupling': self.coupling_strength,
            'mode': self.mode,
            'sub_state': self.sub_state,
            'local': self.local_interactions,
            'distant': self.distant_interactions
        }

