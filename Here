            'id': self.id,
            'data': self.data,
            'history': self.history,
            'created': self.created,
            'updated': self.updated,
            'homes': self.homes
        }
    def save(self, directory="seeds"):
        path = f"{directory}/{self.id}.seed"
        with open(path, 'w') as f:
            json.dump(self.export(), f)

class SeedPortal:
    """Manages seed storage on disk."""
    def __init__(self, storage_dir="seeds"):
        self.storage_dir = storage_dir
        import os
        os.makedirs(storage_dir, exist_ok=True)
        self.seeds = {}
        self._load_all()
    def _load_all(self):
        import glob
        for path in glob.glob(f"{self.storage_dir}/*.seed"):
            try:
                with open(path, 'r') as f:
                    data = json.load(f)
                    seed = Seed(data['data'], data['id'])
                    seed.history = data.get('history', [])
                    seed.created = data.get('created', time.time())
                    seed.updated = data.get('updated', seed.created)
                    seed.homes = data.get('homes', [])
                    self.seeds[seed.id] = seed
            except:
                pass
    def list_seeds(self):
        return [{'id':sid, 'name':s.data.get('name','Unnamed')} for sid,s in self.seeds.items()]
    def plant(self, seed_data):
        seed = Seed(seed_data)
        self.seeds[seed.id] = seed
        seed.save(self.storage_dir)
        return seed.id

