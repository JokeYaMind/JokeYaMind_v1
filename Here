class Biome:
    """Biome grid with nutrients, water, fungi, bacteria, altitude."""
    def __init__(self, w, h):
        self.w = w
        self.h = h
        self.nutrients = np.ones((w, h)) * 0.5
        self.water = np.ones((w, h)) * 0.5
        self.fungi = np.zeros((w, h))
        self.bacteria = np.zeros((w, h))
        self.altitude = self._generate_altitude(w, h)

    def _generate_altitude(self, w, h):
        grid = np.random.rand(w, h)
        for _ in range(3):
            new = np.zeros_like(grid)
            for x in range(w):
                for y in range(h):
                    s, c = 0, 0
                    for dx in (-1,0,1):
                        for dy in (-1,0,1):
                            nx, ny = x+dx, y+dy
                            if 0 <= nx < w and 0 <= ny < h:
                                s += grid[nx,ny]
                                c += 1
                    new[x,y] = s / c
            grid = new
        return grid

    def tick(self, time_sys):
        for x in range(self.w):
            for y in range(self.h):
                rain = 0.1 if time_sys.storm else 0.01
                if random.random() < 0.05:
                    self.water[x,y] = min(1.0, self.water[x,y] + rain)
                evap = 0.01 * time_sys.get_light()
                self.water[x,y] = max(0.0, self.water[x,y] - evap)
                if self.water[x,y] > 0.6 and time_sys.get_light() < 0.3:
                    self.fungi[x,y] = min(1.0, self.fungi[x,y] + 0.01)
                if self.nutrients[x,y] > 0.6:
                    self.bacteria[x,y] = min(1.0, self.bacteria[x,y] + 0.01)
                if self.fungi[x,y] > 0.5 and self.bacteria[x,y] > 0.1:
                    self.bacteria[x,y] *= 0.95
                self.nutrients[x,y] *= 0.999
                if self.bacteria[x,y] > 0.5:
                    self.nutrients[x,y] = min(1.0, self.nutrients[x,y] + 0.002)

    def exude(self, x, y, n, w):
        if 0 <= x < self.w and 0 <= y < self.h:
            self.nutrients[x,y] = min(1.0, self.nutrients[x,y] + n)
            self.water[x,y] = min(1.0, self.water[x,y] + w)

    def is_sea(self, x, y):
        return 0 <= x < self.w and 0 <= y < self.h and self.water[x,y] > 0.6

    def is_mountain(self, x, y):
        return 0 <= x < self.w and 0 <= y < self.h and self.altitude[x,y] > 0.7

class TimeSystem:
    """Day/night, storms, eclipses."""
    def __init__(self):
        self.total_ticks = 0
        self.day = 1
        self.hour = 6
        self.minute = 0
        self.wind_speed = 0.5
        self.wind_dir = 0
        self.storm = False
        self.eclipse = False

    def tick(self):
        self.total_ticks += 1
        day_progress = (self.total_ticks % DAY_LENGTH_TICKS) / DAY_LENGTH_TICKS
        self.hour = int(day_progress * 24)
        self.minute = int((day_progress * 24 * 60) % 60)
        if self.hour == 0 and self.minute == 0:
            self.day = (self.day % 7) + 1
        self.wind_speed = max(0.0, min(1.0, self.wind_speed + random.uniform(-0.05, 0.05)))
        self.wind_dir = (self.wind_dir + random.randint(-5, 5)) % 360
        if not self.storm and random.random() < 0.005:
            self.storm = True
        elif self.storm and random.random() < 0.01:
            self.storm = False
        if not self.eclipse and random.random() < 0.001:
            self.eclipse = True
        elif self.eclipse and random.random() < 0.02:
            self.eclipse = False

    def get_light(self):
        rad = ((self.hour - 6) / 24.0) * 2 * math.pi
        base = (math.sin(rad) + 1) / 2
        if self.eclipse: base *= 0.1
        if self.storm: base *= 0.5
        return max(0.0, min(1.0, base))

