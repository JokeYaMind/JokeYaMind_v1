        self.ratchet_engine = RatchetEngine()

        # Sanctuary
        self.wraith_log = []
        self.ipm = IPM()
        self.global_user_state = UserState.DISENGAGED

        # Joke Ya Mind
        self.wraith_pillar = np.zeros(NDIM)
