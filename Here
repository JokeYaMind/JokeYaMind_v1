def sde_evolution(X, mu, sigma, dt, dW):
    """Stochastic differential equation dX = mu dt + sigma dW."""
    return X + mu * dt + sigma * dW

def correlation(x, y):
    """Covariance between two time series."""
    return np.cov(x, y)[0,1]

def martingale_check(series):
    """Check if series is a martingale (mean of differences zero)."""
    diffs = np.diff(series)
