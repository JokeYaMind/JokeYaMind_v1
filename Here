        self.brat_emissary = BratEmissary()
        self.lucid = LUCID()
        self.memo = MEMO()
        self.atmosphere = AtmosphereEngine()

        # Seed entities
        self._seed_entities()

    def _seed_entities(self):
        role_pool = ["MYSTIC"] + ["SKEPTIC"]*2 + ["FOOL"] + ["NORMAL"]*(8-4)
        random.shuffle(role_pool)
        for i in range(8):
            uid = i
            x = random.randint(5, MAP_W-5)
            y = random.randint(5, MAP_H-5)
            entity = Entity(uid, x, y)
            entity.set_role(role_pool[i])
            self.social_hub.add_entity(entity)
            node = self.lattice.add_node(float(x), float(y), self.biome.altitude[x][y])
            entity.lattice_node = node

    def add_log(self, msg):
        self.social_hub.add_log(msg)

    def tick(self, user_input=None):
        # 1. Carnival
        self.time_sys.tick()
        self.biome.tick(self.time_sys)

        # 2. S.A.M.
        for node in self.lattice.nodes:
            self.lattice.update_node(node, self.time_sys.total_ticks, 0.001)
        self.triad_engine.apply_thermodynamics(self.lattice.nodes, 0.001)
        for node in self.lattice.nodes:
            self.psycho_engine.update_state(node, 0.001)
            self.psycho_engine.process_time_flies(node, 0.001)
            porosity = self.chemistry_engine.update_chemistry(node, 0.001)
            self.chemistry_engine.porosity_map[id(node)] = porosity
            self.chemistry_engine.filter_genetics(node)
            self.bio_engine.update_microbes(node, 0.001)
            self.bio_engine.update_predator_prey(node, 0.001)
        self.bio_engine.update_isopods(self.lattice.nodes, 0.001)
        if self.ratchet_engine.check_criticality(self.lattice.nodes, self.time_sys.total_ticks):
            self.add_log("Ratchet criticality event!")

        # 3. Joke Ya Mind
        N = self.riddlebox.step()
        self.damion += 0.1 * N + 0.05 * self.seed
        self.damion *= (1 - GAMMA_MEMBRANE)
        self.seed += self.damion + self.juggalo
        self.seed += np.sign(self.seed) * 0.01
        self.juggalo += 0.5 * (self.seed + self.damion)
        flux = self.environment * FLUX_STRENGTH
        self.membrane.update(self.p_field, N, flux)
        self.high_mem.store(self.membrane.M, N, self.p_field, flux)
        self.low_mem.store(self.membrane.M, N, self.p_field, flux)
        self.high_mem.decay()
        self.low_mem.decay()
        self.bridges.detect_bridges(self.high_mem.psi, self.low_mem.psi)
        self.wraith_pillar = self.seed.copy()
        self.p_field = ALPHA*self.p_field + BETA*N + GAMMA*flux

        # 4. Entities
        for e in self.social_hub.entities:
            e.update(self.biome, self.litho, self.time_sys, self.theology,
                     self.add_log, self.ratchet_events,
                     lattice_engine=self.lattice, dt=0.001,
                     jym_field=self.membrane.M,
                     global_tick=self.time_sys.total_ticks)

        # 5. Reproduction
        alive = [e for e in self.social_hub.entities if e.alive]
        new_borns = []
        for i, e1 in enumerate(alive):
            for j, e2 in enumerate(alive):
                if i >= j: continue
                if abs(e1.x - e2.x) <= 1 and abs(e1.y - e2.y) <= 1:
                    if e1.gender != e2.gender and e1.energy > 40 and e2.energy > 40:
                        if random.random() < 0.1:
                            e1.energy -= 20
                            e2.energy -= 20
                            child_uid = len(self.social_hub.entities) + len(new_borns)
                            child = Entity(child_uid, e1.x, e1.y)
                            for gene in child.genes:
