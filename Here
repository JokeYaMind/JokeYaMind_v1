def rotation_matrix_4d(angle, plane=(0,1)):
    """Simple rotation in 4D – rotates in the given plane."""
    theta = angle
    c, s = np.cos(theta), np.sin(theta)
    R = np.eye(NDIM)
    i, j = plane[0], plane[1]
    R[i,i] = c
    R[i,j] = -s
    R[j,i] = s
    R[j,j] = c
    return R

class Membrane:
    def __init__(self):
        self.M = np.zeros(NDIM)
        self.M_stab1 = np.zeros(NDIM)
        self.M_stab2 = np.zeros(NDIM)
        self.tension = 0.0
        self.phase = 0.0  # for rotation
    def update(self, p, N, E, dt=0.01):
        # apply forces
        self.M += ALPHA * p + BETA * N + GAMMA * E * np.ones(NDIM)
        self.M *= (1 - GAMMA_MEMBRANE)
        self.M_stab1 += 0.5 * (self.M - self.M_stab1)
        self.M_stab2 += 0.5 * (self.M - self.M_stab2)
        self.tension = np.linalg.norm(self.M_stab1 - self.M_stab2)
        # apply 4D rotation (spin) – rotate in random plane each tick
        self.phase += GOLDEN_ANGLE * dt
        plane = random.choice([(0,1),(0,2),(0,3),(1,2),(1,3),(2,3)])
        R = rotation_matrix_4d(self.phase, plane)
        self.M = R @ self.M
    def pop(self):
        return self.tension > THRESHOLD_POP

class MemoryField:
    def __init__(self, name, resolution='high'):
        self.name = name
        self.resolution = resolution
        self.psi = np.zeros(NDIM)
        self.energy = 0.0
    def store(self, M, N, p, E):
        H = 0.05 * (M + N + p + E)
        if self.resolution == 'low':
            H *= 0.5
        self.psi += H
        self.energy = np.sum(self.psi**2)
    def decay(self):
        self.psi *= (1 - GAMMA_MEMORY)
        self.energy = np.sum(self.psi**2)

class RNGratchet:
    def __init__(self):
        self.state = np.zeros(NDIM)
        self.phase = np.zeros(NDIM)
    def step(self):
        raw = np.random.choice([-1, 0, 1], size=NDIM)
        self.phase += GOLDEN_ANGLE
        return raw * STOCHASTIC_AMP

def kink_solution(x, center, width):
    """Soliton profile."""
    return np.tanh((x - center) / width)

class BridgeNetwork:
    def __init__(self):
        self.bridges = []  # list of (pos1, pos2, strength)
        self.percolation = 0.0
    def detect_bridges(self, M_high, M_low, threshold=0.8):
        dist = np.linalg.norm(M_high - M_low)
        if dist < threshold:
            strength = 1.0 - dist/threshold
            self.bridges.append((M_high.copy(), M_low.copy(), strength))
            if len(self.bridges) > 100:
                self.bridges.pop(0)
        # percolation = fraction of dimensions where high and low are close
        close_dims = np.sum(np.abs(M_high - M_low) < 0.3) / NDIM
        self.percolation = close_dims
        return dist < threshold
    def compute_percolation(self):
        return self.percolation

