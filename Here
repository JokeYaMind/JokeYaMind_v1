class BridgeNetworkFull(BridgeNetwork):
    def compute_percolation(self, total_nodes):
        if total_nodes == 0:
            return 0.0
        unique = set()
        for high, low in self.bridges:
            unique.add(tuple(high))
            unique.add(tuple(low))
        return len(unique) / total_nodes


