def config_command(engine):
    """Interactive parameter tuning."""
    print("\n=== CONFIGURATION ===")
    print("Available parameters:")
    params = {
        '1': ('Global resonance', 'global_resonance', 0.0, 1.0),
        '2': ('Membrane tension threshold', 'THRESHOLD_POP', 0.1, 2.0),
